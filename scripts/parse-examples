#! /usr/bin/env bash
#
# Run OCaml parsers on test files in test/ok and test/xfail directories,
# executing all parses in parallel.
#
# This is a thin wrapper that delegates to the Rust bench-runner binary
# for parallel execution. Falls back to the original bash implementation
# if the binary is not found.
#
set -eu -o pipefail

progdir=$(dirname "$0")

rust_bin="$progdir/bench-runner/target/release/parse-examples"

if [[ -x "$rust_bin" ]]; then
  exec "$rust_bin" "$@"
else
  echo "Warning: Rust parse-examples binary not found at $rust_bin" >&2
  echo "Falling back to sequential bash implementation." >&2
  echo "Build with: cd $progdir/bench-runner && cargo build --release" >&2
  exec "$progdir/parse-examples.bash" "$@"
fi
