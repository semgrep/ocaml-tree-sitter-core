#! /usr/bin/env bash
#
# Fetch git projects from a list and run our parser on the files for
# a language of interest, parsing all files in parallel.
#
# This is a thin wrapper that delegates to the Rust bench-runner binary
# for parallel execution. Falls back to the original bash implementation
# if the binary is not found.
#
set -eu -o pipefail

progdir=$(dirname "$0")

rust_bin="$progdir/bench-runner/target/release/lang-stat"

if [[ -x "$rust_bin" ]]; then
  exec "$rust_bin" "$@"
else
  echo "Warning: Rust lang-stat binary not found at $rust_bin" >&2
  echo "Falling back to sequential bash implementation." >&2
  echo "Build with: cd $progdir/bench-runner && cargo build --release" >&2
  exec "$progdir/lang-stat.bash" "$@"
fi
